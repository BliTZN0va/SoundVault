<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="SoundVault" Language="1033" Version="1.0.2"
           Manufacturer="SoundVault" UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of SoundVault is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="..\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/GamerZ/soundvault" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="ARPNOMODIFY" Value="1" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLDIR" Name="SoundVault">
          <Component Id="SoundVaultExe" Guid="*">
            <File Id="SoundVaultExe" Name="SoundVault.exe" Source="..\dist\SoundVault.exe" KeyPath="yes">
              <Shortcut Id="DesktopShortcut" Directory="DesktopFolder"
                        Name="SoundVault" WorkingDirectory="INSTALLDIR"
                        Icon="AppIcon" IconIndex="0" Advertise="no" />
              <Shortcut Id="StartMenuShortcut" Directory="ProgramMenuFolder"
                        Name="SoundVault" WorkingDirectory="INSTALLDIR"
                        Icon="AppIcon" IconIndex="0" Advertise="no" />
            </File>
          </Component>
          <Component Id="IconFile" Guid="*">
            <File Id="IconFile" Name="icon.ico" Source="..\icon.ico" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <Directory Id="DesktopFolder" />
      <Directory Id="ProgramMenuFolder" />
    </Directory>

    <Feature Id="MainFeature" Title="SoundVault" Level="1">
      <ComponentRef Id="SoundVaultExe" />
      <ComponentRef Id="IconFile" />
    </Feature>
  </Product>
</Wix>
